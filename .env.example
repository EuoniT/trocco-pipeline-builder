# TROCCO Pipeline Builder 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
#
# .env.local は .gitignore に含まれるため、安全に機密情報を記載できます。

# ─── TROCCO（必須）─────────────────────────────────────
# TROCCO管理画面 > APIキー管理 から取得
# APIアクセスにはAdvanced以上のプランが必要
TROCCO_API_KEY=""

# ─── kintone（kintoneソースを使う場合）───────────────────
# kintone開発者ライセンス: https://kintone.dev/en/developer-license-registration-form/
#
# 【モードA】既存接続を使う（推奨）:
#   TROCCO管理画面で kintone 接続を事前に作成し、そのIDを設定
#   確認: curl -s "https://trocco.io/api/connections/kintone" \
#          -H "Authorization: Token $TROCCO_API_KEY" \
#          | jq '.items[] | {id, name}'
KINTONE_CONNECTION_ID=""
#
# 【モードB】Terraformで新規作成:
#   KINTONE_CONNECTION_ID を空にすると、以下の情報でTerraformが接続を新規作成
KINTONE_DOMAIN="your-subdomain.cybozu.com"
KINTONE_APP_ID="1"
KINTONE_API_TOKEN="your_kintone_api_token"

# ─── Snowflake（Snowflakeデスティネーションを使う場合）────
# Snowflake無料トライアル: https://signup.snowflake.com/
#
# 【モードA】既存接続を使う:
#   TROCCO管理画面で Snowflake 接続を事前に作成し、そのIDを設定
SNOWFLAKE_CONNECTION_ID=""
#
# 【モードB】Terraformで新規作成:
#   SNOWFLAKE_CONNECTION_ID を空にすると、以下の情報でTerraformが接続を新規作成
SNOWFLAKE_HOST="your-account.snowflakecomputing.com"
SNOWFLAKE_USER="TROCCO_USER"
SNOWFLAKE_PASSWORD="your_snowflake_password"
SNOWFLAKE_WAREHOUSE="COMPUTE_WH"
SNOWFLAKE_DATABASE="DEMO_DB"
SNOWFLAKE_SCHEMA="PUBLIC"
SNOWFLAKE_ROLE="SYSADMIN"

# ─── MySQL（MySQLソースを使う場合）─────────────────────
# MYSQL_HOST="localhost"
# MYSQL_PORT="3306"
# MYSQL_USER="root"
# MYSQL_PASSWORD=""
# MYSQL_DATABASE=""

# ─── BigQuery（BigQueryデスティネーションを使う場合）──────
# TROCCO管理画面でBigQuery接続を作成し、そのIDを設定
# 接続ID確認: curl -s "https://trocco.io/api/connections/bigquery" -H "Authorization: Token $TROCCO_API_KEY" | jq '.items[] | {id, name}'
BQ_CONNECTION_ID=""
BQ_DATASET=""
BQ_TABLE=""
BQ_LOCATION="asia-northeast1"
